# AWS 共通
AWS_PROFILE=dev
AWS_DEFAULT_REGION=ap-northeast-1

# AWS IoT Core
IOT_ENDPOINT=xxxxxxxxxx.iot.ap-northeast-1.amazonaws.com

# バックエンド (ローカル用)
DYNAMODB_TABLE_ROBOTS=robops-robots-dev
DYNAMODB_TABLE_SCHEDULES=robops-schedules-dev
DYNAMODB_TABLE_OTA_JOBS=robops-ota-jobs-dev
TIMESTREAM_DATABASE=robops-dev
TIMESTREAM_TABLE=telemetry

# フロントエンド (Vite)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
